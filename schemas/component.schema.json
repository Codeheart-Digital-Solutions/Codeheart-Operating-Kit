{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Codeheart-Digital-Solutions/Codeheart-Operating-Kit/schemas/component.schema.json",
  "title": "Codeheart Operating Kit Component Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "component"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "name",
        "description",
        "profiles",
        "consumer_impact",
        "ownership_modes",
        "files"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "version": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "profiles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "consumer_impact": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "ownership_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/ownership" },
          "uniqueItems": true
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/file" }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "purpose", "profile_applicability", "plugin_selector"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "purpose": { "type": "string", "minLength": 1 },
              "profile_applicability": { "type": "string", "minLength": 1 },
              "plugin_selector": { "type": "string", "minLength": 1 }
            }
          }
        },
        "validators": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "inputs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "ownership": {
      "type": "string",
      "enum": ["managed", "scaffold", "template", "generated-surface", "local-user", "local-machine"]
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "ownership"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "ownership": { "$ref": "#/$defs/ownership" },
        "install_when": {
          "type": "string",
          "enum": ["absent", "always", "conditional"]
        },
        "install_mode": {
          "type": "string",
          "enum": ["copy", "managed-block"]
        },
        "presence_policy": { "$ref": "#/$defs/presence" },
        "update_strategy": { "$ref": "#/$defs/update" },
        "removal_strategy": { "$ref": "#/$defs/removal" },
        "route_id": { "type": "string", "minLength": 1 }
      }
    },
    "presence": {
      "type": "string",
      "enum": ["required", "create-when-absent", "optional", "conditional", "historical-only"]
    },
    "update": {
      "type": "string",
      "enum": ["replace", "managed-section", "preserve", "append-only", "report-only"]
    },
    "removal": {
      "type": "string",
      "enum": ["reconcile", "preserve", "explicit-migration"]
    }
  }
}
