{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Codeheart-Digital-Solutions/Codeheart-Operating-Kit/schemas/release-catalog.schema.json",
  "title": "Codeheart Operating Kit External Release Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "assets"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "platform", "url", "archive_sha256", "pack_manifest_sha256"],
        "properties": {
          "name": { "type": "string", "pattern": "^codeheart-operating-kit-[0-9]+\\.[0-9]+\\.[0-9]+-(macos-universal|windows-x64)\\.zip$" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "platform": { "type": "string", "enum": ["macos-universal", "windows-x64"] },
          "url": { "type": "string", "minLength": 1 },
          "archive_sha256": { "$ref": "#/$defs/sha256" },
          "pack_manifest_sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    }
  },
  "$defs": { "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" } }
}
