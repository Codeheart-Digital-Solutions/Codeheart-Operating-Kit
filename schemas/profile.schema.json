{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Codeheart-Digital-Solutions/Codeheart-Operating-Kit/schemas/profile.schema.json",
  "title": "Codeheart Operating Kit Profile Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "name",
        "description",
        "selected_components",
        "generated_surfaces",
        "state_defaults",
        "update_check"
      ],
      "properties": {
        "id": { "type": "string", "const": "standard" },
        "version": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "selected_components": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "generated_surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface" }
        },
        "state_defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": ["managed", "scaffold", "template", "generated-surface", "local-user", "local-machine"],
          "properties": {
            "managed": { "$ref": "#/$defs/strategies" },
            "scaffold": { "$ref": "#/$defs/strategies" },
            "template": { "$ref": "#/$defs/strategies" },
            "generated-surface": { "$ref": "#/$defs/strategies" },
            "local-user": { "$ref": "#/$defs/strategies" },
            "local-machine": { "$ref": "#/$defs/strategies" }
          }
        },
        "update_check": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cadence_days", "current_result_agent_message", "update_available_agent_message"],
          "properties": {
            "cadence_days": { "type": "integer", "minimum": 1 },
            "current_result_agent_message": { "type": "string", "const": "silent" },
            "update_available_agent_message": { "type": "string", "const": "prompt-user-before-apply" }
          }
        }
      }
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "ownership", "source"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "ownership": {
          "type": "string",
          "enum": ["managed", "scaffold", "template", "generated-surface", "local-user", "local-machine"]
        },
        "source": { "type": "string", "minLength": 1 },
        "install_when": {
          "type": "string",
          "enum": ["absent", "always", "conditional"]
        },
        "presence_policy": {
          "type": "string",
          "enum": ["required", "create-when-absent", "optional", "conditional", "historical-only"]
        },
        "update_strategy": {
          "type": "string",
          "enum": ["replace", "managed-section", "preserve", "append-only", "report-only"]
        },
        "removal_strategy": {
          "type": "string",
          "enum": ["reconcile", "preserve", "explicit-migration"]
        }
      }
    },
    "strategies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["presence_policy", "update_strategy", "removal_strategy"],
      "properties": {
        "presence_policy": {
          "type": "string",
          "enum": ["required", "create-when-absent", "optional", "conditional", "historical-only"]
        },
        "update_strategy": {
          "type": "string",
          "enum": ["replace", "managed-section", "preserve", "append-only", "report-only"]
        },
        "removal_strategy": {
          "type": "string",
          "enum": ["reconcile", "preserve", "explicit-migration"]
        }
      }
    }
  }
}
